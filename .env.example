# TinaCMS Environment Variables
# Copy this file to .env and fill in the values from your TinaCloud project (https://app.tina.io)

# Your TinaCloud Client ID
TINA_CLIENT_ID=

# Your TinaCloud Content (Read-only) Token
TINA_TOKEN=

# Optional: The branch you are working on (defaults to main)
# TINA_BRANCH=main

# Feature Flags
VITE_ENABLE_BLOG=false
VITE_ENABLE_EVENTS=false
